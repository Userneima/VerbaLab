# Environment variables for core verb learning system
# Copy to .env and adjust as needed

# port that Vite listens on (development) or preview listens on (production)
VITE_PORT=5173
# full URL the app is served at (optional, overrides default)
#APP_URL=http://localhost:5173
# NODE_ENV=development or production (defaults to development)

# ========= Supabase (public) =========
# Your Supabase Project ID (from Project Settings)
VITE_SUPABASE_PROJECT_ID=
# Your Supabase anon public key (Project Settings -> API -> anon public)
VITE_SUPABASE_ANON_KEY=
# Your deployed Edge Function slug (default from this repo)
VITE_SUPABASE_FUNCTION_SLUG=make-server-1fc434d6
# Supabase Dashboard → Edge Functions → Secrets: CORS_ALLOW_ORIGINS=https://你的线上域名
# （浏览器出现 Failed to fetch 多为 CORS 或断网；本仓库 Edge 已放行任意 localhost/127.0.0.1 端口）
